model Session {
    id            String   @id @default(uuid())
    clientId      String
    browserType   String
    url           String
    hostname      String
    pathname      String
    meta          Json?
    durationMs    Int
    startedAt     DateTime
    endedAt       DateTime
    matchedRules  String
    primaryRuleId String?
    recordedAt    DateTime @default(now())
}

