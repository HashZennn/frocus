{
  "name": "frocus-sidecar",
  "version": "1.0.0",
  "description": "Node.js WebSocket Sidecar for Frocus",
  "main": "src/ws-server.ts",
  "scripts": {
    "dev": "bun run src/ws-server.ts",
    "build": "tsc",
    "bun:build": "bun build src/ws-server.ts --compile --outfile ../desktop/src-tauri/binaries/ws-server",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.45.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.8.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "@biomejs/biome": "2.4.5"
  }
}
