{
  "name": "frocus-sidecar",
  "version": "1.0.0",
  "description": "Node.js WebSocket Sidecar for Frocus",
  "main": "src/ws-server.ts",
  "scripts": {
    "dev": "tsx src/ws-server.ts",
    "build": "tsc",
    "package": "npm run build && pkg dist/ws-server.js --targets node18-linux-arm64,node18-macos-arm64,node18-macos-x64,node18-win-x64 --out-path ../src-tauri/binaries"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/ws": "^8.5.10",
    "pkg": "^5.8.1",
    "prisma": "^5.14.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
